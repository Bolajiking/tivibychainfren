# TVinBio — all optional. App runs in mock mode when these are unset.

# Supabase (data + realtime)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Privy (auth + embedded wallet). When set, real auth turns on.
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=
# Optional JWT verification key override. The Privy Node SDK can fetch JWKS with app credentials.
PRIVY_VERIFICATION_KEY=

# Livepeer (live + VOD). Server only — never exposed.
LIVEPEER_API_KEY=
# Signing secret for the Livepeer webhook (stream.started / stream.idle →
# /api/livepeer/webhook). Set the same value when creating the webhook in
# Livepeer Studio. Without it the webhook receiver fail-closes (503).
LIVEPEER_WEBHOOK_SECRET=

# Browser-live bridge (spec: production-browser-live-bridge-design). Server only.
# Master switch: off (or missing URL/secret) → desktop plans are direct-only and
# mobile receives an explicit bridge-unavailable result — identical to pre-bridge
# behavior. OBS is never affected.
TVINBIO_BRIDGE_ENABLED=false
# HTTPS control origin of the bridge agent (e.g. https://bridge.example.com:8443).
TVINBIO_BRIDGE_CONTROL_URL=
# Shared HMAC-SHA256 control secret. Exists only here and in the agent env.
TVINBIO_BRIDGE_CONTROL_SECRET=
# Optional diagnostics-safe label of the bridge signaling origin shown in the
# creator diagnostics disclosure. Never a credential.
NEXT_PUBLIC_TVINBIO_BRIDGE_SIGNALING_ORIGIN=

# Payments — USDC on Base
NEXT_PUBLIC_BASE_USDC_CONTRACT=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
NEXT_PUBLIC_BASE_CHAIN_ID=8453
BASE_RPC_URL=https://mainnet.base.org
# Gas sponsorship (paymaster) + fiat on-ramp provider keys
PAYMASTER_URL=
ONRAMP_PROVIDER=
